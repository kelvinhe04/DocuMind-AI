# ============================================================
# DocuMind AI — Variables de entorno (frontend / Next.js)
# Copia este archivo como .env.local y completa los valores
# ============================================================

# ------------------------------------------------------------
# Clerk (Auth) — https://dashboard.clerk.com
# Crea una nueva aplicación, activa Email + Google OAuth
# ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<pegar-clave-publishable-de-clerk>
CLERK_SECRET_KEY=<pegar-clave-secreta-de-clerk>
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ------------------------------------------------------------
# Stripe (Pagos, modo test) — https://dashboard.stripe.com
# Crea 3 Products con precio recurrente mensual:
#   Starter $49/mes, Business $199/mes, Enterprise $999/mes
# Copia los IDs de precio (price_xxx) de cada producto
# ------------------------------------------------------------
STRIPE_SECRET_KEY=<pegar-clave-secreta-de-stripe-modo-test>
STRIPE_PRICE_STARTER=<price_xxx-plan-starter>
STRIPE_PRICE_BUSINESS=<price_xxx-plan-business>
STRIPE_PRICE_ENTERPRISE=<price_xxx-plan-enterprise>

# ------------------------------------------------------------
# App / Backend
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
FASTAPI_URL=http://localhost:8000
