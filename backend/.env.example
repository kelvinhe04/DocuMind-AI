# ===== GROQ (LLM) =====
# Si está vacío, la app usa MODO EXTRACTIVO automáticamente (nunca se cae).
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ===== BASES DE DATOS / PATHS =====
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/documind.db
UPLOADS_DIR=./data/uploads
DEMO_DIR=./data/demo

# ===== EMBEDDINGS =====
# Modelo all-MiniLM-L6-v2 vía ChromaDB (ONNX, local). Dejar el default.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===== CHUNKING / RAG =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
MAX_TOKENS_RESPONSE=1024
TEMPERATURE=0.1

# ===== OCR (Windows) =====
# Ajustar a tu instalación de Tesseract y Poppler.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_LANG=spa
OCR_DPI=300
POPPLER_PATH=C:\poppler\Library\bin
